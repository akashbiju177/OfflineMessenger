<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#000000"
    android:gravity="center">

    <TextView
        android:text="IDENTITY CONFIG"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#00E5FF"
        android:layout_marginBottom="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvUuid"
        android:text="ID: ..."
        android:textColor="#888888"
        android:fontFamily="monospace"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etNickname"
        android:hint="Enter Nickname"
        android:textColor="#FFFFFF"
        android:textColorHint="#555555"
        android:backgroundTint="#00E5FF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnSaveParams"
        android:text="SAVE IDENTITY"
        android:backgroundTint="#00E5FF"
        android:textColor="#000000"
        android:layout_marginTop="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnResetNetwork"
        android:text="RESET NETWORK"
        android:backgroundTint="#FF9800"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnWipe"
        android:text="EMERGENCY WIPE"
        android:backgroundTint="#F44336"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>