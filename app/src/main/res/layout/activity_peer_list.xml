<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp">

    <!-- ================= SCANNNER LAYOUT ================= -->
    <LinearLayout
        android:id="@+id/layout_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:text="ACTIVE UPLINKS"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnScan"
            android:text="RESTART SCAN"
            android:backgroundTint="#009688"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvPeerStatus"
            android:text="My Handle: ..."
            android:textColor="#00E5FF"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvEmpty"
            android:text="Scanning..."
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginTop="50dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPeers"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>

    <!-- ================= CHAT LAYOUT ================= -->
    <LinearLayout
        android:id="@+id/layout_chat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvChatStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONNECTED: Host"
            android:textColor="#00FF00"
            android:textStyle="bold"
            android:textSize="18sp"
            android:padding="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#111111"
            android:padding="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Type payload..."
                android:textColorHint="#555555"
                android:background="#222222"
                android:padding="10dp"/>

            <ImageButton
                    android:id="@+id/btnMic"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginLeft="4dp"
                    android:layout_marginRight="4dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#00E5FF"/>

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginLeft="5dp"
                android:backgroundTint="#00E5FF"
                android:src="@android:drawable/ic_menu_send"
                android:contentDescription="Send"
                android:padding="8dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
