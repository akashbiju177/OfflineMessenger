<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hive_dark">

    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/hive_surface"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvTargetName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PRIVATE CHANNEL"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPrivateChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/headerBg"
        app:layout_constraintBottom_toTopOf="@id/inputLayout"/>

    <LinearLayout
        android:id="@+id/inputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#1A1A1A"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/etPrivateMessage"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Encrypted Message..."
            android:textColor="@color/white"
            android:textColorHint="#80FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="4dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/hive_accent"/>

        <ImageButton
            android:id="@+id/btnSendPrivate"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/hive_accent"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
